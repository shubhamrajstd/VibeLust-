<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:ads="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:layout_above="@+id/adBannerFrame">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- Title Bar / Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_alignParentLeft="true">

                    <!-- Premium Icon Box -->
                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/brand_icon_background"
                        android:layout_marginRight="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✧"
                            android:textColor="#FFD700"
                            android:textSize="20sp"
                            android:layout_gravity="center" />
                    </FrameLayout>

                    <!-- Title Words -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vibe Lust"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Premium Wallpapers"
                            android:textColor="#FFD700"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Elegant Menu Indicator dots -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentRight="true"
                    android:layout_centerInParent="true"
                    android:gravity="end">

                    <View
                        android:layout_width="20dp"
                        android:layout_height="2.5dp"
                        android:background="#E1E1E1"
                        android:layout_marginBottom="4dp" />
                    <View
                        android:layout_width="20dp"
                        android:layout_height="2.5dp"
                        android:background="#E1E1E1"
                        android:layout_marginBottom="4dp" />
                    <View
                        android:layout_width="12dp"
                        android:layout_height="2.5dp"
                        android:background="#E1E1E1" />
                </LinearLayout>

            </RelativeLayout>

            <!-- Main Central Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="36dp"
                android:paddingHorizontal="24dp"
                android:layout_marginBottom="24dp">

                <!-- Inner Icon circle plate -->
                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/inner_icon_background"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📽️"
                        android:textSize="36sp"
                        android:layout_gravity="center" />
                </FrameLayout>

                <!-- Engine Title text -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Live Engine"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="sans-serif-light" />

                <!-- Description text -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select a high-quality video to transform your home screen into a living canvas."
                    android:textColor="#8A8A8A"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"
                    android:gravity="center"
                    android:layout_marginBottom="32dp" />

                <!-- Action gold button -->
                <Button
                    android:id="@+id/btnPickVideo"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/button_gold_background"
                    android:backgroundTint="@null"
                    android:text="+ PICK GALLERY VIDEO"
                    android:textColor="#111111"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:elevation="0dp"
                    android:stateListAnimator="@null" />

                <!-- Active status pill -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="24dp"
                    android:alpha="0.6">

                    <!-- Small blinking green dot -->
                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:background="#FF4CAF50"
                        android:layout_marginRight="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MEDIA CORE ACTIVE"
                        android:textColor="#E1E1E1"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />
                </LinearLayout>

            </LinearLayout>

            <!-- Metadata Info Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Left Auto-Trim column info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/sub_card_background"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginRight="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AUTO-TRIM"
                        android:textColor="#FFD700"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5s Loops"
                        android:textColor="#E1E1E1"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Right Battery-Safe info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/sub_card_background"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginLeft="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OPTIMIZATION"
                        android:textColor="#FFD700"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Battery Safe"
                        android:textColor="#E1E1E1"
                        android:textSize="13sp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Ad Banner Space with Dark `#0A0A0A` block and thin separator -->
    <LinearLayout
        android:id="@+id/adBannerFrame"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#0A0A0A"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        android:gravity="center">

        <!-- Top border for Ad block -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1AFFFFFF" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="4dp">

            <!-- Banner Container -->
            <LinearLayout
                android:id="@+id/adBannerContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <com.google.android.gms.ads.AdView
                    android:id="@+id/adView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    ads:adSize="BANNER"
                    ads:adUnitId="ca-app-pub-5879858884847224~9426458717" />
            </LinearLayout>

        </FrameLayout>
    </LinearLayout>

</RelativeLayout>
